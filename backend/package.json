{
  "name": "@yehager/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Wave 1 backend foundation (Hono + PostgreSQL + Drizzle + Kysely)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/scripts/apply-migrations.js && node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/scripts/apply-migrations.ts",
    "auth:create-admin": "tsx src/scripts/create-admin.ts",
    "sync:dry": "tsx src/scripts/sync-base44.ts --dry-run",
    "sync:run": "tsx src/scripts/sync-base44.ts",
    "sync:parity": "tsx src/scripts/sync-parity-check.ts",
    "smoke:phase7": "tsx src/scripts/smoke-phase7.ts"
  },
  "keywords": [
    "hono",
    "postgres",
    "drizzle",
    "kysely"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-s3": "^3.1080.0",
    "@aws-sdk/s3-request-presigner": "^3.1080.0",
    "@hono/node-server": "^2.0.1",
    "@hono/zod-validator": "^0.7.6",
    "@types/nodemailer": "^8.0.1",
    "cloudinary": "^2.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.16",
    "jose": "^6.2.3",
    "kysely": "^0.28.16",
    "nodemailer": "^7.0.13",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.16.0",
    "stripe": "^18.1.1",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
